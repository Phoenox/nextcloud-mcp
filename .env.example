# Your Nextcloud instance URL (no trailing slash)
# tsdav uses /.well-known/caldav for service discovery.
# If discovery fails, try pointing directly to the DAV root:
#   https://your-nextcloud.example.com/remote.php/dav
NEXTCLOUD_URL=https://your-nextcloud.example.com

NEXTCLOUD_USERNAME=your.username

# Use a Nextcloud app password (Settings → Security → Devices & sessions)
NEXTCLOUD_APP_PASSWORD=xxxx-xxxx-xxxx-xxxx-xxxx

# ---- HTTP / OAuth transport (optional) ----
# Set all three to enable the HTTP server alongside stdio.

# Public base URL of this MCP server (must be HTTPS in production)
MCP_BASE_URL=https://mcp.example.com

# Password shown in the OAuth login form when Claude.ai connects
OAUTH_ADMIN_PASSWORD=change-me

# Port the HTTP server listens on (default: 3000)
MCP_HTTP_PORT=3000
